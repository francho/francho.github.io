{
  "name": "francho.org",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "francho.org",
  "author": "Francho Joven",
  "keywords": [
    "gatsby"
  ],
  "scripts": {
    "develop": "gatsby develop --host 0.0.0.0",
    "start": "gatsby develop",
    "build": "gatsby build",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "typecheck": "tsc --noEmit",
    "audit": "pnpm audit --audit-level=high",
    "postinstall": "pnpm audit --audit-level=high"
  },
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "gatsby": "^5.16.0",
    "gatsby-plugin-image": "^3.16.0",
    "gatsby-plugin-mdx": "^5.16.0",
    "gatsby-plugin-postcss": "^6.16.0",
    "gatsby-plugin-react-svg": "^3.3.0",
    "gatsby-plugin-sharp": "^5.16.0",
    "gatsby-plugin-sitemap": "^6.16.0",
    "gatsby-remark-images": "^7.16.0",
    "gatsby-source-filesystem": "^5.16.0",
    "gatsby-transformer-sharp": "^5.16.0",
    "postcss": "^8.5.6",
    "postcss-modules": "^6.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^3.0.1"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp": ">=0.1.12"
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "gh-pages": "^6.3.0",
    "svg-react-loader": "^0.4.6",
    "typescript": "^5.3.3"
  }
